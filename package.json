{
  "name": "neojaundice",
  "version": "2.4.1",
  "description": "NeoJaundice — Neonatal Jaundice Screening System",
  "main": "app.js",
  "scripts": {
    "start": "http-server . -p 3000 -o --cors -c-1",
    "test": "jest --verbose --colors",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage --verbose"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "collectCoverageFrom": ["app.core.js"],
    "coverageReporters": ["text", "html"],
    "coverageDirectory": "coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@jest/globals": "^29.7.0"
  },
  "keywords": ["healthcare", "neonatal", "jaundice", "screening"],
  "author": "NeoJaundice Team",
  "license": "MIT"
}
